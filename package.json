{
  "name": "deck-of-mandate",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "compress": "node scripts/compressAssets.mjs",
    "compress:sunking": "node scripts/compressAssets.mjs sunking",
    "img:sunking-bg": "node scripts/compressAssets.mjs sunking",
    "test": "node scripts/runVitest.mjs",
    "test:ai:first-mandate:1000": "npx tsx src/levels/sunking/cli/firstMandateReport.ts --seed-start 1 --runs 1000",
    "test:ai:a-strategy-i:1000": "npx tsx src/levels/sunking/cli/secondMandateAndCampaignReport.ts --seed-start 1 --runs 1000",
    "test:ai:first-to-third:5000": "node scripts/runFirstToThirdCampaignBatch.mjs",
    "test:ai:menu-standalone:5000": "node scripts/runMenuStandaloneChaptersBatch.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
